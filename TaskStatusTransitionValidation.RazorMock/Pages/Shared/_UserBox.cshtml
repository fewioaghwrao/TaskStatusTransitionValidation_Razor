@model TaskStatusTransitionValidation.RazorMock.Models.MeDto

<div class="projects-userbox">
    <div class="user-chip">
        @Model.DisplayName
        <span class="user-chip__role">(@Model.Role)</span>
    </div>

    <form method="post" asp-page="/Logout" id="logoutForm">
        <button type="submit" class="btn btn-dark" id="logoutButton">ログアウト</button>
    </form>
</div>

<div id="logoutModal" class="logout-modal" aria-hidden="true">
    <div class="logout-modal__backdrop"></div>

    <div class="logout-modal__panel"
         role="dialog"
         aria-modal="true"
         aria-labelledby="logoutModalTitle"
         aria-describedby="logoutModalMessage">
        <h2 id="logoutModalTitle" class="logout-modal__title">ログアウト確認</h2>

        <p id="logoutModalMessage" class="logout-modal__message">
            ログアウトします。よろしいですか？
        </p>

        <div class="logout-modal__actions">
            <button type="button" class="btn btn-secondary" id="cancelLogoutButton">キャンセル</button>
            <button type="button" class="btn btn-danger" id="confirmLogoutButton">ログアウトする</button>
        </div>
    </div>
</div>

<style>
    .logout-modal {
        position: fixed;
        inset: 0;
        display: none;
        z-index: 1000;
    }

        .logout-modal.is-open {
            display: block;
        }

    .logout-modal__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
    }

    .logout-modal__panel {
        position: relative;
        width: min(420px, calc(100% - 32px));
        margin: 120px auto 0;
        background: #1a1a1a;
        color: #e5e7eb;
        border: 1px solid #2a2a2a;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 18px 60px rgba(0, 0, 0, 0.45);
    }

    .logout-modal__title {
        margin: 0 0 10px;
        font-size: 20px;
        font-weight: 700;
    }

    .logout-modal__message {
        margin: 0;
        color: #cbd5e1;
        line-height: 1.7;
    }

    .logout-modal__actions {
        margin-top: 18px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-secondary {
        background: #2a2a2a;
        color: #e5e7eb;
        border: 1px solid #3a3a3a;
        border-radius: 10px;
        padding: 8px 14px;
        cursor: pointer;
    }

        .btn-secondary:hover {
            background: #333333;
        }

    .btn-danger {
        background: #b91c1c;
        color: #ffffff;
        border: 1px solid #dc2626;
        border-radius: 10px;
        padding: 8px 14px;
        cursor: pointer;
    }

        .btn-danger:hover {
            background: #dc2626;
        }
</style>

<script>
    (function () {
        const form = document.getElementById("logoutForm");
        const logoutButton = document.getElementById("logoutButton");
        const modal = document.getElementById("logoutModal");
        const cancelButton = document.getElementById("cancelLogoutButton");
        const confirmButton = document.getElementById("confirmLogoutButton");
        const backdrop = modal ? modal.querySelector(".logout-modal__backdrop") : null;

        if (!form || !logoutButton || !modal || !cancelButton || !confirmButton) {
            return;
        }

        let confirmed = false;

        function openModal() {
            modal.classList.add("is-open");
            modal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
            confirmButton.focus();
        }

        function closeModal() {
            modal.classList.remove("is-open");
            modal.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
            logoutButton.focus();
        }

        form.addEventListener("submit", function (e) {
            if (confirmed) {
                return;
            }

            e.preventDefault();
            openModal();
        });

        cancelButton.addEventListener("click", function () {
            closeModal();
        });

        confirmButton.addEventListener("click", function () {
            confirmed = true;

            // 共通ローダー表示用
            document.dispatchEvent(new CustomEvent("show-loader"));

            // クラス監視型の既存処理に寄せたい場合の保険
            logoutButton.classList.add("js-show-loader");

            form.submit();
        });

        if (backdrop) {
            backdrop.addEventListener("click", function () {
                closeModal();
            });
        }

        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape" && modal.classList.contains("is-open")) {
                closeModal();
            }
        });
    })();
</script>